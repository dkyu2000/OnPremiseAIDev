{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm-onprem/main-nemotron",
  "provider": {
    "litellm-onprem": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "On-Prem LiteLLM (LG CNS WISE)",
      "options": {
        "baseURL": "http://localhost:4000/v1",
        "apiKey": "{env:OPENCODE_LITELLM_KEY}"
      },
      "models": {
        "main-nemotron": {
          "name": "Main — Nemotron-3-Super-120B (선택지 L: NVFP4 단독)",
          "limit": {
            "context": 120000,
            "output": 4096
          }
        }
      }
    }
  }
}
