{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm-onprem/main-llama",
  "provider": {
    "litellm-onprem": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "On-Prem LiteLLM (LG CNS WISE)",
      "options": {
        "baseURL": "http://localhost:4000/v1",
        "apiKey": "{env:OPENCODE_LITELLM_KEY}"
      },
      "models": {
        "main-llama": {
          "name": "Main — Llama 3.3-70B (FP8)",
          "limit": { "context": 27648, "output": 4096 }
        },
        "sub-gemma": {
          "name": "Sub — Gemma 2-9B (FP8) [채팅 전용·도구 미지원, 현재 미기동]",
          "limit": { "context": 8192, "output": 2048 }
        }
      }
    }
  }
}
