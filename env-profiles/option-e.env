# 선택지 E(현재 운영 채택, 2026-07-13~) — gpt-oss-120b(MXFP4) + StarCoder2-7B FP8
# 실측(완료보고서 §17): main weights 65.97GiB(KV 여유 6.46GiB @ max-model-len 27648),
# autocomplete weights 6.96GiB(KV 여유 2.39GiB). GPU 총사용 92,396MiB / 여유 5,491MiB(5.4GiB).
# ★[2026-07-14 재튜닝, 완료보고서 §18.12] 사용자 편의를 위해 컨텍스트 상향: MAIN_MAX_LEN
#   27648→32768(+18.5%), MAIN_GPU_UTIL 0.80→0.81. 실측 KV 7.41GiB/107,888토큰(풀컨텍스트 기준
#   동시성 약 3.3명 — 참고: 이전 "동시성 5.23x" 표기는 실측 재검증 결과 부정확했던 것으로 판명,
#   27648/0.80 기준 실제로도 약 3.4명이었음. 즉 이번 재튜닝은 동시성 손실 거의 없이 컨텍스트만
#   확장한 결과). GPU 총사용 93,424MiB / 여유 3,818MiB(3.7GB, 선택지 D의 3.5~4.5GB와 동급 안전
#   마진). 클라이언트(`opencode.json`)의 `context`도 26000→30000으로 함께 상향.
# ★main은 Llama 계열이 아닌 별도 아키텍처(OpenAI gpt-oss, 표준 MoE) → served-model-name도
#   main-gptoss로 변경(§13의 "같은 계열 내 스왑은 이름 고정" 원칙과 다름 — 아키텍처가 아예 바뀌므로
#   "main-llama"로 두면 로그/감사기록/클라이언트 UI에서 실제 모델을 오인하게 됨).
# ★SM120 MXFP4 백엔드 미인식으로 Marlin 커널 폴백 경고가 뜨나 실사용 성능 저하는 미미(185 tok/s 실측).
# ★gpt-oss는 harmony 포맷(reasoning+content 분리)이라 Llama보다 완결까지 훨씬 많은 토큰이 필요
#   (품질 PoC §17.8: 어려운 질문은 900토큰은 있어야 안전, 320은 부족해 답이 잘리는 사례 있었음).
#   클라이언트 max_tokens 기본값을 이 프로파일 적용 시 함께 올릴 것(OPERATOR_GUIDE §10 참조).
# ★FIM은 StarCoder2-7B(15B 대비 VRAM 절반)라 §13에서 확인한 7B의 EOS 불안정(정답 뒤 garbage 생성)
#   트레이드오프가 있음 — LiteLLM stop 토큰으로 완화되나 완전 해결은 아님.
# 상세: docs/VALIDATION_COMPLETION_REPORT.md §17
LABEL="선택지 E: gpt-oss-120b MXFP4 + StarCoder2-7B FP8 (GPU 여유 ~5.4GB, 운영 채택 — 채팅/에이전트 품질·속도 우위, FIM 7B 트레이드오프)"
MAIN_CLIENT_LABEL="Main — gpt-oss-120b (선택지 E: MXFP4)"
AUTOCOMPLETE_CLIENT_LABEL="StarCoder2-7B (선택지 E: FP8)"
MAIN_MODEL_PATH=/models/gpt-oss-120b
MAIN_SERVED_NAME=main-gptoss
MAIN_TOOL_PARSER=openai
MAIN_EXTRA_ARGS=--reasoning-parser openai_gptoss
# ★[2026-07-15] vLLM v0.20.2부터 이 플래그=1은 SM120 미지원 백엔드 강제로 기동 거부됨 — 반드시 0(§19.2)
MAIN_MXFP4_FLASHINFER=0
MAIN_GPU_UTIL=0.81
MAIN_MAX_LEN=32768
MAIN_CLIENT_CONTEXT=30000
AUTOCOMPLETE_MODEL_PATH=/models/starcoder2-7b-fp8
AUTOCOMPLETE_GPU_UTIL=0.11
AUTOCOMPLETE_MAX_LEN=8192
