# .env.example  →  복사해서 .env 로 사용 (.env 는 .gitignore 처리, 시크릿 평문 커밋 금지)

# ── 시크릿 (필수) ─────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-CHANGE-ME-strong-random   # 서버 측 전용. 클라이언트엔 절대 노출 금지
POSTGRES_PASSWORD=CHANGE-ME-strong-random

# ── 이미지 태그 (빌드 시점에 확정 후 고정 / latest 금지) ───────
# ★VLLM_IMAGE 는 반드시 SM120 FP8 지원 확인 후 정확한 버전으로 고정 (★2026-07-15 v0.20.2로 운영 전환 — §19.3, MAIN_MXFP4_FLASHINFER=0 필수)
VLLM_IMAGE=vllm/vllm-openai:v0.20.2
# OSS 무료 라인(1.86~1.89 중 1개). audit_logger(FR-5/7)에 asyncpg 필요 → litellm/Dockerfile 로 내장한 커스텀 이미지 사용.
#   빌드: docker build -t onprem-litellm:v1.89.0-asyncpg ./litellm   (폐쇄망: 이 이미지를 사전 스테이징 반입)
LITELLM_IMAGE=onprem-litellm:v1.89.0-asyncpg
POSTGRES_IMAGE=postgres:16
PRESIDIO_ANALYZER_IMAGE=mcr.microsoft.com/presidio-analyzer:2.2.355
PRESIDIO_ANONYMIZER_IMAGE=mcr.microsoft.com/presidio-anonymizer:2.2.355

# ── 모델 경로 (사전 스테이징된 FP8/NVFP4 가중치) ────────────────
MODELS_DIR=./models
# 기대 디렉터리:
#   ./models/llama-3.1-8b-instruct-fp8      (Phase A/B 메인 프록시, 검증용)
#   ./models/gemma-2-9b-it-fp8              (Phase B 서브, 검증용 — 운영 미사용)
#   ./models/gemma-2-27b-it-fp8             (Phase C 운영 서브 실검증 — 운영 미사용)
#   ./models/llama-3.3-70b-instruct-fp8     (구 운영 메인, ~70GB — 2026-07-08 NVFP4로 대체)
#   ./models/llama-3.3-70b-instruct-nvfp4   (★운영 메인, phase-prod — RedHatAI NVFP4, ~40GB)
#   ./models/starcoder2-7b-fp8              (구 FIM, ~7.4GB — 2026-07-08 15B로 대체)
#   ./models/starcoder2-15b-fp8             (★운영 FIM, phase-prod — RedHatAI FP8, ~15.4GB)

# ★phase-prod에서 vllm-main/vllm-autocomplete가 로드할 모델 경로. 검증(phase-a/b/ide)으로 되돌리려면
#   8B/7B 경로로 변경.
MAIN_MODEL_PATH=/models/llama-3.1-8b-instruct-fp8        # 운영: /models/llama-3.3-70b-instruct-nvfp4
AUTOCOMPLETE_MODEL_PATH=/models/starcoder2-7b-fp8         # 운영: /models/starcoder2-15b-fp8

# ── VRAM 분할 / 컨텍스트 ───────────────────────────────────────
# 검증 장비(32GB, Phase A/B 듀얼 동시상주) 기본값:
MAIN_GPU_UTIL=0.45
SUB_GPU_UTIL=0.40
MAIN_MAX_LEN=16384
SUB_MAX_LEN=8192
# Phase A에서 main 단독 실행 시 더 크게: MAIN_GPU_UTIL=0.85 로 override 가능
# Phase C(Gemma 27B 단독):
GEMMA27B_GPU_UTIL=0.92
GEMMA27B_MAX_LEN=8192
# IDE 자동완성(FIM) — StarCoder2-7B (phase-ide). Llama(main)와 동시 상주(0.45+0.30):
#   ★Llama/Gemma(instruct)는 FIM 미지원 → tab 자동완성엔 FIM 전용 코드모델 필수. ./models/starcoder2-7b-fp8
AUTOCOMPLETE_GPU_UTIL=0.30
AUTOCOMPLETE_MAX_LEN=8192

# ★운영(phase-prod, RTX PRO 6000 96GB) 채택 구성(2026-07-08 갱신): main NVFP4(~40GB) + FIM StarCoder2-15B FP8(~15.4GB).
#   [실측] MAIN_GPU_UTIL=0.72(weights 39.89GiB, KV 여유 26.2GiB) / MAIN_MAX_LEN=27648 /
#   AUTOCOMPLETE_GPU_UTIL=0.20(weights 15.43GiB, KV 여유 2.14GiB) / AUTOCOMPLETE_MAX_LEN=8192.
#   GPU 총사용 ~90.5GB/97.9GB(여유 ~4.5GB). ★반드시 main→autocomplete 순차 기동으로 튜닝할 것 — 두 vLLM을
#   동시에 올리면 서로의 메모리 프로파일링 시점에 상대가 자리잡기 전 상태를 참조해 실제보다 훨씬 부족하게
#   계산되어 기동 실패한다(실측: 동시기동 시 main -2.73GiB, autocomplete -33.84GiB로 각각 실패).
#   (구 선택지 A: main FP8(~70GB)+FIM 7B(~7GB), MAIN_GPU_UTIL=0.83/MAX_LEN=27648/AUTOCOMPLETE_GPU_UTIL=0.10,
#   여유 30MiB로 매우 타이트했음 — 상세 시행착오는 `.env`/완료보고서 §11.6, §13 참조)

# ── Gemma2 attention 백엔드 (★Blackwell SM120) ────────────────
# Gemma 2(sub/prod)는 logit soft-capping → 기본 FlashInfer. SM120 head_size 이슈로 기동 실패 시
# FLASH_ATTN 으로 전환해 softcap 지원 FlashAttention 빌드로 재시도(TEST_PLAN B-1/Phase C 검증항목).
# 값: FLASHINFER | FLASH_ATTN
GEMMA_ATTN_BACKEND=FLASHINFER
